# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://devflow:devflow@localhost:5432/devflow"
SUPABASE_URL="https://your-project-ref.supabase.co"
# Optional, server-side only. Used by npm run seed:demo to create demo auth users.
SUPABASE_SERVICE_ROLE_KEY=""
# Optional fallback for npm run seed:demo when service-role access is unavailable and public signup is enabled.
SUPABASE_ANON_KEY=""

# Optional demo seed overrides.
# DEMO_PROJECT_ID="demo-persona-project"
# DEMO_PM_EMAIL="devflow.pm@example.com"
# DEMO_DEV_EMAIL="devflow.dev@example.com"
# DEMO_CLIENT_EMAIL="devflow.client@example.com"
# DEMO_AUTH_PASSWORD="DevFlowDemo123!"

# ─────────────────────────────────────────────
# AI Models
# ─────────────────────────────────────────────
# mock runs the local deterministic agent provider and does not require AI keys.
# Use llm only when a supported provider API key is configured.
AGENT_PROVIDER="mock"
LLM_PROVIDER="openrouter"
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_MODEL="deepseek/deepseek-v4-flash:free"
OPENROUTER_FALLBACK_MODEL="nvidia/nemotron-3-nano-30b-a3b:free"
# Optional OpenRouter attribution headers.
OPENROUTER_SITE_URL="http://localhost:4000"
OPENROUTER_APP_NAME="DevFlow"

# Alternate real provider. Set LLM_PROVIDER="openai" to use this path.
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_FALLBACK_MODEL=""
OPENAI_API_KEY=""

# OpenCode Go uses an OpenAI-compatible endpoint. Set LLM_PROVIDER="opencode" to use this path.
OPENCODE_BASE_URL="https://opencode.ai/zen/go/v1"
OPENCODE_MODEL="deepseek-v4-flash"
OPENCODE_FALLBACK_MODEL="deepseek-v4-pro"
OPENCODE_API_KEY=""

# Alternate real provider. Set LLM_PROVIDER="anthropic" to use this path.
ANTHROPIC_BASE_URL="https://api.anthropic.com/v1"
ANTHROPIC_MODEL="claude-3-5-haiku-20241022"
ANTHROPIC_FALLBACK_MODEL=""
ANTHROPIC_VERSION="2023-06-01"
ANTHROPIC_API_KEY=""

# ─────────────────────────────────────────────
# GitHub App credentials
# The private key may be base64-encoded from the PEM file:
#   base64 -w 0 your-app.private-key.pem
# Raw PEM and escaped-newline PEM values are also normalized at runtime.
# ─────────────────────────────────────────────
GITHUB_APP_ID="123456"
# Recommended: encode your .pem file: base64 -w 0 your-app.private-key.pem
GITHUB_PRIVATE_KEY="<base64-encoded PEM key>"
GITHUB_INSTALLATION_ID="12345678"
GITHUB_ORG="alphaexplora-generated"

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
PORT=4000
NODE_ENV="development"
# Restrict in production: CORS_ORIGIN="https://your-frontend.com"
CORS_ORIGIN="*"

# ─────────────────────────────────────────────
# LangSmith (Phase 2E — enable for observability)
# ─────────────────────────────────────────────
LANGCHAIN_API_KEY="ls__..."
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_PROJECT="devflow"

# ─────────────────────────────────────────────
# Phase 2B — RunSupervisor
# ─────────────────────────────────────────────
# SUPERVISOR_POLL_INTERVAL_MS=30000      # How often supervisor polls for stuck runs
# SUPERVISOR_STUCK_THRESHOLD_MS=300000   # A run is "stuck" if no event logged in this window
