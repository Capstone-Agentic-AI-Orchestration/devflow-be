generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

model Project {
  id          String          @id @default(cuid())
  companyName String
  brief       String          @db.Text
  stackKey    String
  status      ProjectStatus   @default(PENDING)
  runId       String?         @unique
  repoUrl     String?
  createdById String?         @db.Uuid
  createdBy   Profile?        @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  gates       GateEvent[]
  artifacts   Artifact[]
  eventLogs   EventLog[]
  runBudget   RunBudget?
  members     ProjectMember[]
  tasks       ProjectTask[]
  timelineEvents ProjectTimelineEvent[]
  workOrders  WorkOrder[]
  conversations ProjectConversation[]
  collaborationDocuments CollaborationDocument[]
  clientInvites ClientInvite[]
  kickoff     ProjectKickoff?
  deliveryReview ProjectDeliveryReview?
  orchestrationRuns OrchestrationRun[]
  workOrderExecutions WorkOrderExecution[]

  @@index([createdById])
}

enum InquiryStatus {
  NEW
  APPROVED
  REJECTED
}

model ClientInquiry {
  id                String        @id @default(cuid())
  companyName       String
  contactName       String
  email             String
  phone             String?
  role              String?
  brief             String        @db.Text
  stackKey          String        @default("nextjs-nestjs-supabase")
  budgetRange       String?
  timeline          String?
  status            InquiryStatus @default(NEW)
  reviewNote        String?       @db.Text
  reviewedById      String?       @db.Uuid
  reviewedBy        Profile?      @relation("InquiryReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt        DateTime?
  approvedProjectId String?
  clientInvite      ClientInvite?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([email])
  @@index([reviewedById])
  @@map("client_inquiries")
}

enum ClientInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum ProjectKickoffStatus {
  DRAFT
  READY
  LOCKED
}

model ClientInvite {
  id           String             @id @default(cuid())
  inquiryId    String             @unique
  inquiry      ClientInquiry      @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  projectId    String             @unique
  project      Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  email        String
  contactName  String
  companyName  String
  status       ClientInviteStatus @default(PENDING)
  createdById  String?            @db.Uuid
  createdBy    Profile?           @relation("InviteCreator", fields: [createdById], references: [id], onDelete: SetNull)
  acceptedById String?            @db.Uuid
  acceptedBy   Profile?           @relation("InviteAcceptor", fields: [acceptedById], references: [id], onDelete: SetNull)
  acceptedAt   DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([email, status])
  @@index([createdById])
  @@index([acceptedById])
  @@map("client_invites")
}

model ProjectKickoff {
  id                     String               @id @default(cuid())
  projectId              String               @unique
  project                Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scopeSummary           String?              @db.Text
  milestones             String?              @db.Text
  requiredDocuments      String?              @db.Text
  techStackNotes         String?              @db.Text
  deliveryRoles          String?              @db.Text
  readinessNotes         String?              @db.Text
  scopeConfirmed         Boolean              @default(false)
  milestonesConfirmed    Boolean              @default(false)
  documentsConfirmed     Boolean              @default(false)
  techStackConfirmed     Boolean              @default(false)
  rolesConfirmed         Boolean              @default(false)
  clientAccessConfirmed  Boolean              @default(false)
  initialTasksCreated    Boolean              @default(false)
  initialWorkOrdersCreated Boolean            @default(false)
  status                 ProjectKickoffStatus @default(DRAFT)
  completedById          String?              @db.Uuid
  completedBy            Profile?             @relation("KickoffCompleter", fields: [completedById], references: [id], onDelete: SetNull)
  completedAt            DateTime?
  updatedById            String?              @db.Uuid
  updatedBy              Profile?             @relation("KickoffUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@index([status])
  @@index([completedById])
  @@index([updatedById])
  @@map("project_kickoffs")
}

model GateEvent {
  id        String       @id @default(cuid())
  projectId String
  project   Project      @relation(fields: [projectId], references: [id])
  gateType  GateType
  decision  GateDecision
  notes     String?      @db.Text
  decidedAt DateTime     @default(now())

  @@index([projectId])
}

model Artifact {
  id            String               @id @default(cuid())
  projectId     String
  project       Project              @relation(fields: [projectId], references: [id])
  agentType     String
  filePath      String
  content       String               @db.Text
  clientVisible Boolean              @default(false)
  displayName   String?
  sharedAt      DateTime?
  reviewStatus  ArtifactReviewStatus @default(PENDING)
  reviewNote    String?              @db.Text
  reviewedAt    DateTime?
  reviewedById  String?              @db.Uuid
  outputReviewStatus ArtifactOutputReviewStatus @default(PENDING)
  outputReviewNote String?           @db.Text
  outputReviewedAt DateTime?
  outputReviewedById String?         @db.Uuid
  publishedAt DateTime?
  publishedById String?              @db.Uuid
  revisionHandledAt DateTime?
  revisionHandledById String?         @db.Uuid
  revisionResolutionNote String?      @db.Text
  createdAt     DateTime             @default(now())
  tasks         ProjectTask[]
  workOrders    WorkOrder[]
  workOrderExecutions WorkOrderExecution[]

  @@index([projectId])
  @@index([projectId, clientVisible])
  @@index([projectId, outputReviewStatus])
}

enum ArtifactReviewStatus {
  PENDING
  APPROVED
  REVISION_REQUESTED
}

enum ArtifactOutputReviewStatus {
  PENDING
  APPROVED
  REWORK_REQUESTED
  PUBLISHED
}

enum ProjectStatus {
  PENDING
  PARSING_REQUIREMENTS
  NEGOTIATING_CONTRACT
  AWAITING_GATE_1
  GENERATING_CODE
  AWAITING_GATE_2
  COMMITTING
  DELIVERED
  FAILED
}

enum GateType {
  ARCHITECTURE_REVIEW
  CODE_REVIEW
}

enum GateDecision {
  APPROVED
  REJECTED
}

enum UserRole {
  CLIENT
  PM
  DEV
  ADMIN
}

enum ProjectTaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

model Profile {
  id              String          @id @db.Uuid
  email           String?         @unique
  fullName        String?
  role            UserRole        @default(CLIENT)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdProjects Project[]       @relation("ProjectCreatedBy")
  memberships     ProjectMember[]
  assignedTasks    ProjectTask[]   @relation("TaskAssignee")
  createdTasks     ProjectTask[]   @relation("TaskCreator")
  createdWorkOrders WorkOrder[]     @relation("WorkOrderCreator")
  taskActivities   ProjectTaskActivity[] @relation("TaskActivityActor")
  notifications    Notification[]  @relation("NotificationRecipient")
  sentNotifications Notification[] @relation("NotificationActor")
  timelineEvents  ProjectTimelineEvent[] @relation("TimelineActor")
  createdConversations ProjectConversation[] @relation("ConversationCreator")
  messages        ProjectMessage[] @relation("MessageAuthor")
  messageReads    ConversationRead[]
  uploadedDocuments CollaborationDocument[] @relation("DocumentUploader")
  reviewedDocuments CollaborationDocument[] @relation("DocumentReviewer")
  reviewedInquiries ClientInquiry[] @relation("InquiryReviewer")
  createdClientInvites ClientInvite[] @relation("InviteCreator")
  acceptedClientInvites ClientInvite[] @relation("InviteAcceptor")
  completedKickoffs ProjectKickoff[] @relation("KickoffCompleter")
  updatedKickoffs ProjectKickoff[] @relation("KickoffUpdater")
  acceptedDeliveries ProjectDeliveryReview[] @relation("DeliveryAcceptor")
  requestedDeliveryRevisions ProjectDeliveryReview[] @relation("DeliveryRevisionRequester")
  resolvedDeliveryRevisions ProjectDeliveryReview[] @relation("DeliveryRevisionResolver")

  @@map("profiles")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String   @db.Uuid
  role      UserRole
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

model ProjectTask {
  id           String            @id @default(cuid())
  projectId    String
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  artifactId   String?
  artifact     Artifact?         @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  title        String
  description  String?           @db.Text
  status       ProjectTaskStatus @default(TODO)
  assignedToId String?           @db.Uuid
  assignedTo   Profile?          @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById  String?           @db.Uuid
  createdBy    Profile?          @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  activities   ProjectTaskActivity[]
  workOrders   WorkOrder[]

  @@index([projectId, status])
  @@index([assignedToId, status])
  @@index([artifactId])
  @@map("project_tasks")
}

enum ProjectTaskActivityType {
  TASK_CREATED
  STATUS_CHANGED
  ASSIGNEE_CHANGED
  ARTIFACT_CHANGED
  COMMENT
}

model ProjectTaskActivity {
  id        String                  @id @default(cuid())
  projectId String
  taskId    String
  task      ProjectTask             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actorId   String?                 @db.Uuid
  actor     Profile?                @relation("TaskActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  type      ProjectTaskActivityType
  message   String?                 @db.Text
  metadata  Json                    @default("{}")
  createdAt DateTime                @default(now())

  @@index([projectId, taskId, createdAt])
  @@index([actorId])
  @@map("project_task_activities")
}

enum NotificationType {
  INQUIRY_SUBMITTED
  INQUIRY_APPROVED
  INQUIRY_REJECTED
  CLIENT_INVITE_ACCEPTED
  ARTIFACT_REVIEWED
  REVISION_HANDLED
  ARTIFACT_PUBLISHED
  ARTIFACT_REWORK_REQUESTED
  DELIVERY_ACCEPTED
  DELIVERY_REVISION_REQUESTED
  DELIVERY_REVISION_RESOLVED
  TASK_ASSIGNED
  TASK_STATUS_CHANGED
  TASK_COMMENTED
  WORK_ORDER_CREATED
  WORK_ORDER_DISPATCHED
  WORK_ORDER_STATUS_CHANGED
  COLLAB_MESSAGE_SENT
  COLLAB_DOCUMENT_UPLOADED
  COLLAB_DOCUMENT_REVIEWED
}

enum ProjectTimelineEventType {
  PROJECT_CREATED
  PROJECT_UPDATED
  CLIENT_INVITE_ACCEPTED
  MEMBER_ADDED
  MEMBER_REMOVED
  ARTIFACT_SHARED
  ARTIFACT_UNSHARED
  ARTIFACT_REVIEWED
  REVISION_HANDLED
  ARTIFACT_OUTPUT_REVIEWED
  ARTIFACT_PUBLISHED
  ARTIFACT_REWORK_REQUESTED
  DELIVERY_ACCEPTED
  DELIVERY_REVISION_REQUESTED
  DELIVERY_REVISION_RESOLVED
  TASK_CREATED
  TASK_ASSIGNED
  TASK_STATUS_CHANGED
  TASK_COMMENTED
  NOTIFICATION_SENT
  WORK_ORDER_CREATED
  WORK_ORDER_DISPATCHED
  WORK_ORDER_STATUS_CHANGED
  COLLAB_CONVERSATION_CREATED
  COLLAB_MESSAGE_SENT
  COLLAB_DOCUMENT_UPLOADED
  COLLAB_DOCUMENT_REVIEWED
}

enum ProjectDeliveryReviewStatus {
  PENDING
  ACCEPTED
  REVISION_REQUESTED
  REVISION_RESOLVED
}

model ProjectDeliveryReview {
  id                    String                      @id @default(cuid())
  projectId             String                      @unique
  project               Project                     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status                ProjectDeliveryReviewStatus @default(PENDING)
  acceptanceNote        String?                     @db.Text
  acceptedById          String?                     @db.Uuid
  acceptedBy            Profile?                    @relation("DeliveryAcceptor", fields: [acceptedById], references: [id], onDelete: SetNull)
  acceptedAt            DateTime?
  revisionNote          String?                     @db.Text
  revisionRequestedById String?                     @db.Uuid
  revisionRequestedBy   Profile?                    @relation("DeliveryRevisionRequester", fields: [revisionRequestedById], references: [id], onDelete: SetNull)
  revisionRequestedAt   DateTime?
  revisionResolvedById  String?                     @db.Uuid
  revisionResolvedBy    Profile?                    @relation("DeliveryRevisionResolver", fields: [revisionResolvedById], references: [id], onDelete: SetNull)
  revisionResolvedAt    DateTime?
  resolutionNote        String?                     @db.Text
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  @@index([status])
  @@index([acceptedById])
  @@index([revisionRequestedById])
  @@index([revisionResolvedById])
  @@map("project_delivery_reviews")
}

enum CollaborationVisibility {
  TEAM
  CLIENT
}

enum ConversationCategory {
  GENERAL
  DELIVERY
  CONTRACT
  SUPPORT
}

model ProjectConversation {
  id            String                  @id @default(cuid())
  projectId     String
  project       Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title         String
  category      ConversationCategory    @default(GENERAL)
  visibility    CollaborationVisibility @default(TEAM)
  createdById   String?                 @db.Uuid
  createdBy     Profile?                @relation("ConversationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  lastMessageAt DateTime?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  messages      ProjectMessage[]
  reads         ConversationRead[]

  @@index([projectId, visibility, lastMessageAt])
  @@index([createdById])
  @@map("project_conversations")
}

model ProjectMessage {
  id             String              @id @default(cuid())
  projectId      String
  conversationId String
  conversation   ProjectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  authorId       String?             @db.Uuid
  author         Profile?            @relation("MessageAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  body           String              @db.Text
  createdAt      DateTime            @default(now())

  @@index([projectId, createdAt])
  @@index([conversationId, createdAt])
  @@index([authorId])
  @@map("project_messages")
}

model ConversationRead {
  id             String              @id @default(cuid())
  conversationId String
  conversation   ProjectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String              @db.Uuid
  user           Profile             @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime            @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_reads")
}

enum CollaborationDocumentKind {
  REQUIREMENT
  CONTRACT
  DELIVERABLE
  GENERAL
}

enum CollaborationDocumentStatus {
  DRAFT
  UPLOADED
  APPROVAL_REQUESTED
  APPROVED
  REVISION_REQUESTED
  ARCHIVED
}

model CollaborationDocument {
  id             String                      @id @default(cuid())
  projectId      String
  project        Project                     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  artifactId     String?
  title          String
  description    String?                     @db.Text
  fileName       String?
  externalUrl    String?
  kind           CollaborationDocumentKind   @default(GENERAL)
  status         CollaborationDocumentStatus @default(UPLOADED)
  clientVisible  Boolean                     @default(false)
  uploadedById   String?                     @db.Uuid
  uploadedBy     Profile?                    @relation("DocumentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  reviewedById   String?                     @db.Uuid
  reviewedBy     Profile?                    @relation("DocumentReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNote     String?                     @db.Text
  reviewedAt     DateTime?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  @@index([projectId, clientVisible, status])
  @@index([uploadedById])
  @@index([reviewedById])
  @@map("collaboration_documents")
}

enum WorkOrderAgentType {
  FRONTEND
  BACKEND
  DATABASE
  ARCHITECTURE
  CONTRACT
}

enum WorkOrderStatus {
  DRAFT
  READY
  DISPATCHED
  COMPLETED
  FAILED
  CANCELLED
}

enum WorkOrderPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum OrchestrationRunStatus {
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum OrchestrationRunTrigger {
  START
  RERUN_READY_WORK_ORDERS
  WORK_ORDER_DISPATCH
  RETRY_FAILED_WORK_ORDER
}

enum WorkOrderExecutionStatus {
  RUNNING
  SUCCEEDED
  FAILED
}

model WorkOrder {
  id          String             @id @default(cuid())
  projectId   String
  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId      String?
  task        ProjectTask?       @relation(fields: [taskId], references: [id], onDelete: SetNull)
  artifactId  String?
  artifact    Artifact?          @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  title       String
  instructions String?           @db.Text
  agentType   WorkOrderAgentType
  status      WorkOrderStatus    @default(DRAFT)
  priority    WorkOrderPriority  @default(NORMAL)
  createdById String?            @db.Uuid
  createdBy   Profile?           @relation("WorkOrderCreator", fields: [createdById], references: [id], onDelete: SetNull)
  executionRunId String?
  executionAttempt Int           @default(0)
  executionStartedAt DateTime?
  executionCompletedAt DateTime?
  executionError String?         @db.Text
  lastEventAt DateTime?
  dispatchedAt DateTime?
  completedAt  DateTime?
  failedAt     DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  executions   WorkOrderExecution[]

  @@index([projectId, status])
  @@index([taskId])
  @@index([artifactId])
  @@index([createdById])
  @@index([executionRunId])
  @@index([status, lastEventAt])
  @@map("work_orders")
}

model OrchestrationRun {
  id              String                  @id @default(cuid())
  projectId       String
  project         Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  runId           String                  @unique
  providerMode    String                  @default("mock")
  trigger         OrchestrationRunTrigger @default(START)
  status          OrchestrationRunStatus  @default(RUNNING)
  currentNode     String?
  error           String?                 @db.Text
  actorId         String?                 @db.Uuid
  readyWorkOrders Int                     @default(0)
  completedWorkOrders Int                 @default(0)
  failedWorkOrders Int                    @default(0)
  completedArtifacts Int                  @default(0)
  startedAt       DateTime                @default(now())
  completedAt     DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  executions      WorkOrderExecution[]

  @@index([projectId, createdAt])
  @@index([projectId, status])
  @@index([actorId])
  @@map("orchestration_runs")
}

model WorkOrderExecution {
  id                 String                   @id @default(cuid())
  projectId          String
  project            Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  orchestrationRunId String?
  orchestrationRun   OrchestrationRun?        @relation(fields: [orchestrationRunId], references: [id], onDelete: SetNull)
  workOrderId        String
  workOrder          WorkOrder                @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  artifactId         String?
  artifact           Artifact?                @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  executionRunId     String                   @unique
  attempt            Int
  agentType          WorkOrderAgentType
  status             WorkOrderExecutionStatus @default(RUNNING)
  error              String?                  @db.Text
  startedAt          DateTime                 @default(now())
  completedAt        DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  metadata           Json                     @default("{}")

  @@index([projectId, startedAt])
  @@index([orchestrationRunId])
  @@index([workOrderId])
  @@index([artifactId])
  @@map("work_order_executions")
}

enum ProjectTimelineVisibility {
  INTERNAL
  TEAM
  CLIENT
}

model ProjectTimelineEvent {
  id         String                    @id @default(cuid())
  projectId  String
  project    Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actorId    String?                   @db.Uuid
  actor      Profile?                  @relation("TimelineActor", fields: [actorId], references: [id], onDelete: SetNull)
  taskId     String?
  artifactId String?
  type       ProjectTimelineEventType
  visibility ProjectTimelineVisibility @default(TEAM)
  title      String
  body       String?                   @db.Text
  metadata   Json                      @default("{}")
  createdAt  DateTime                  @default(now())

  @@index([projectId, visibility, createdAt])
  @@index([actorId])
  @@index([taskId])
  @@index([artifactId])
  @@map("project_timeline_events")
}

model Notification {
  id          String           @id @default(cuid())
  recipientId String           @db.Uuid
  recipient   Profile          @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actorId     String?          @db.Uuid
  actor       Profile?         @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  projectId   String?
  taskId      String?
  artifactId  String?
  type        NotificationType
  title       String
  body        String?          @db.Text
  metadata    Json             @default("{}")
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  @@index([recipientId, readAt, createdAt])
  @@index([projectId])
  @@index([taskId])
  @@index([artifactId])
  @@map("notifications")
}

// ─── Phase 2A: Agent Memory ────────────────────────────────────────────────────

model AgentMemory {
  id         String                      @id @default(cuid())
  /// Which agent produced this memory: frontend | backend | database | architecture | contract
  agentType  String
  /// Partition key for similarity search scoping
  memoryType AgentMemoryType
  /// The raw text that was embedded (artifact content or summary)
  content    String                      @db.Text
  /// 1536-dim vector from text-embedding-3-small
  embedding  Unsupported("vector(1536)")
  /// Flexible metadata: stackKey, projectType, complexity, contractId, etc.
  metadata   Json                        @default("{}")
  /// Source project — nullable so global patterns survive project deletion
  projectId  String?
  createdAt  DateTime                    @default(now())

  @@index([agentType, memoryType])
  @@index([projectId])
  @@map("agent_memories")
}

enum AgentMemoryType {
  SKILL // successful agent prompt+output pairs that passed gate review
  PATTERN // fileManifest + contract that resulted in DELIVERED status
  MISTAKE // rejected artifacts with rejection notes
}

// ─── Phase 2B: Run Supervisor ──────────────────────────────────────────────────

model EventLog {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id])
  /// Node name as defined in NODE constant (e.g. "backend_agent")
  nodeName   String
  /// Lifecycle transition: STARTED | COMPLETED | FAILED | RETRIED | STUCK | ESCALATED
  eventType  String
  /// Token counts: { inputTokens: number, outputTokens: number, model: string }
  costMeta   Json     @default("{}")
  /// Cumulative run-level token spend at the time of this event
  runTokens  Int      @default(0)
  occurredAt DateTime @default(now())

  @@index([projectId, occurredAt])
  @@map("event_logs")
}

model RunBudget {
  id             String   @id @default(cuid())
  projectId      String   @unique
  project        Project  @relation(fields: [projectId], references: [id])
  /// Hard token ceiling for this run (default: 200_000)
  tokenBudget    Int      @default(200000)
  /// Tokens consumed so far (charged by RunSupervisor on each node completion)
  tokensConsumed Int      @default(0)
  /// Number of automatic retries already executed
  retryCount     Int      @default(0)
  /// Max auto-retries before escalating to human
  maxRetries     Int      @default(2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("run_budgets")
}
